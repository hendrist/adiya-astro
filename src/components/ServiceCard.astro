---
interface Props {
  title: string;
  description: string;
  href: string;
  features: string[];
  highlight?: boolean;
}

const { title, description, href, features, highlight = false } = Astro.props;
---

<a
  href={href}
  class={`group relative flex flex-col rounded-2xl border-2 p-7 transition-all duration-300 hover:-translate-y-1 hover:shadow-xl ${
    highlight
      ? 'bg-navy border-navy text-white hover:border-gold'
      : 'bg-white border-gray-100 text-gray-800 hover:border-gold'
  }`}
>
  <!-- Badge highlight -->
  {highlight && (
    <span class="absolute -top-3 left-6 bg-gold text-navy text-xs font-bold px-3 py-1 rounded-full">
      Populer
    </span>
  )}

  <!-- Ikon layanan -->
  <div
    class={`w-12 h-12 rounded-xl flex items-center justify-center text-2xl mb-5 ${
      highlight ? 'bg-white/15' : 'bg-cream'
    }`}
  >
    <slot name="icon" />
  </div>

  <!-- Judul -->
  <h3
    class={`text-xl font-bold mb-3 ${highlight ? 'text-white' : 'text-navy'}`}
  >
    {title}
  </h3>

  <!-- Deskripsi -->
  <p
    class={`text-sm leading-relaxed mb-5 ${
      highlight ? 'text-cream/80' : 'text-gray-600'
    }`}
  >
    {description}
  </p>

  <!-- Feature list -->
  <ul class="space-y-2 mb-6 flex-1">
    {features.map((feature) => (
      <li
        class={`flex items-start gap-2 text-sm ${
          highlight ? 'text-cream/90' : 'text-gray-700'
        }`}
      >
        <span class="text-gold mt-0.5 shrink-0">✓</span>
        {feature}
      </li>
    ))}
  </ul>

  <!-- CTA -->
  <div
    class={`inline-flex items-center gap-1.5 text-sm font-semibold transition-colors ${
      highlight
        ? 'text-gold group-hover:text-gold/80'
        : 'text-navy group-hover:text-gold'
    }`}
  >
    Selengkapnya
    <svg
      class="w-4 h-4 transition-transform group-hover:translate-x-1"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
    >
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7" />
    </svg>
  </div>
</a>

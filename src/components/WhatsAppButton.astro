---
interface Props {
  message?: string;
}

const {
  message = 'Halo+Adiya+Printex,+saya+ingin+bertanya+tentang+layanan+printing.',
} = Astro.props;

const waUrl = `https://wa.me/62811142111?text=${message}`;
---

<a
  href={waUrl}
  target="_blank"
  rel="noopener noreferrer"
  class="wa-float group fixed bottom-6 right-6 z-40 flex items-center gap-3"
  aria-label="Chat via WhatsApp"
>
  <!-- Tooltip -->
  <span
    class="hidden sm:block opacity-0 group-hover:opacity-100 translate-x-2 group-hover:translate-x-0 transition-all duration-200 bg-gray-800 text-white text-xs font-medium px-3 py-1.5 rounded-lg whitespace-nowrap shadow-lg pointer-events-none"
  >
    Chat dengan kami
  </span>

  <!-- Tombol + pulse ring -->
  <div class="relative">
    <!-- Pulse ring -->
    <span class="absolute inset-0 rounded-full bg-[#25D366] animate-ping opacity-40"></span>
    <!-- Tombol -->
    <div
      class="relative w-14 h-14 bg-[#25D366] hover:bg-[#20bf5b] rounded-full flex items-center justify-center shadow-lg hover:shadow-xl transition-all duration-200 hover:scale-105"
    >
      <svg class="w-7 h-7 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
        <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.072 23.927l6.235-1.435A11.935 11.935 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.796 9.796 0 0 1-5.017-1.381l-.36-.214-3.7.851.92-3.601-.235-.371A9.795 9.795 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
      </svg>
    </div>
  </div>
</a>

---
const valuePropsList = [
  { icon: '✦', label: 'Kualitas Premium' },
  { icon: '✦', label: 'MOQ Rendah' },
  { icon: '✦', label: 'Pengerjaan Cepat' },
];
---

<section class="bg-navy relative overflow-hidden">
  <!-- Dekorasi latar -->
  <div class="absolute inset-0 pointer-events-none select-none" aria-hidden="true">
    <div class="absolute -top-24 -right-24 w-96 h-96 rounded-full bg-white/5"></div>
    <div class="absolute -bottom-16 -left-16 w-72 h-72 rounded-full bg-white/5"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] rounded-full bg-gold/5"></div>
  </div>

  <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-28 text-center">

    <!-- Logo -->
    <div class="flex justify-center mb-8">
      <div class="bg-white rounded-2xl px-5 py-3 shadow-lg">
        <img
          src="/logo.png"
          alt="Adiya Printex"
          class="h-20 sm:h-24 w-auto"
        />
      </div>
    </div>

    <!-- Headline -->
    <h1 class="text-3xl sm:text-5xl font-bold text-white leading-tight max-w-3xl mx-auto">
      Custom Print Kain &<br />
      <span class="text-gold">Hijab Berkualitas</span><br />
      di Makassar
    </h1>

    <!-- Subheadline -->
    <p class="mt-6 text-cream/80 text-base sm:text-lg max-w-xl mx-auto leading-relaxed">
      Kami melayani Digital Sublime Printing dan Manual Screen Printing
      untuk kebutuhan kain motif dan hijab custom Anda.
    </p>

    <!-- Value props -->
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      {valuePropsList.map((item) => (
        <span class="inline-flex items-center gap-2 bg-white/10 text-cream border border-white/20 text-sm font-medium px-4 py-2 rounded-full">
          <span class="text-gold text-xs">{item.icon}</span>
          {item.label}
        </span>
      ))}
    </div>

    <!-- CTA Buttons -->
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-center gap-4">
      <a
        href="https://wa.me/62811142111?text=Halo+Adiya+Printex,+saya+ingin+konsultasi+dan+pesan+printing."
        target="_blank"
        rel="noopener noreferrer"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 bg-gold text-navy font-bold text-base rounded-lg hover:bg-gold/90 transition-all hover:scale-105 shadow-lg"
      >
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
          <path d="M12 0C5.373 0 0 5.373 0 12c0 2.124.558 4.118 1.532 5.845L.072 23.927l6.235-1.435A11.935 11.935 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.796 9.796 0 0 1-5.017-1.381l-.36-.214-3.7.851.92-3.601-.235-.371A9.795 9.795 0 0 1 2.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
        </svg>
        Pesan Sekarang
      </a>
      <a
        href="#layanan"
        class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 border-2 border-cream/40 text-cream font-semibold text-base rounded-lg hover:border-cream hover:bg-white/5 transition-all"
      >
        Lihat Layanan
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </a>
    </div>

  </div>

  <!-- Wave divider -->
  <div class="relative h-16 sm:h-20" aria-hidden="true">
    <svg
      class="absolute bottom-0 w-full"
      viewBox="0 0 1440 80"
      preserveAspectRatio="none"
      xmlns="http://www.w3.org/2000/svg"
    >
      <path
        d="M0,40 C360,80 1080,0 1440,40 L1440,80 L0,80 Z"
        fill="white"
      />
    </svg>
  </div>
</section>
